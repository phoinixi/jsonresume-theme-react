{
  "name": "jsonresume-theme-react",
  "version": "0.0.3",
  "description": "A React-based theme for JSON Resume",
  "type": "module",
  "main": "index.cjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev:base": "vite",
    "dev": "npm run generate-types && node scripts/dev.js",
    "build": "npm run generate-types && tsc -b && vite build",
    "build:ci": "npm run build && node scripts/render.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "render:resumed": "npm run build && node scripts/render.js",
    "generate-types": "node scripts/generateTypes.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "start": "resumed --theme jsonresume-theme-local",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "jsonresume",
    "jsonresume-theme",
    "resume",
    "cv",
    "react",
    "theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phoinixi/jsonresume-theme-react.git"
  },
  "author": "Francesco Esposito",
  "license": "MIT",
  "dependencies": {
    "@jsonresume/schema": "1.3.0",
    "clsx": "2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^24.2.3",
    "jsonresume-theme-local": "file:./",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.7.4",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@iconify/react": "^5.2.1",
    "@iconify/tailwind": "^1.2.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/i18next": "^12.1.0",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-i18next": "^7.8.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "minimist": "^1.2.8",
    "postcss": "^8.5.15",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.8.4",
    "resumed": "4.1.0",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.48.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3",
    "vite-plugin-compression2": "^1.4.0",
    "vitest": "^3.2.6"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "module": "dist/index.js",
  "files": [
    "dist",
    "index.cjs"
  ],
  "comment": "The files array ensures only the necessary files are included when publishing to npm"
}
